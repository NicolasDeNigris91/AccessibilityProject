# --- Backend ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Set to "true" when running behind a reverse proxy (Railway, Heroku, Nginx, etc.)
# Required for express-rate-limit to see real client IPs via X-Forwarded-For.
TRUST_PROXY=false

# --- MongoDB ---
# Accepts mongodb:// (self-hosted, local) or mongodb+srv:// (Atlas, Railway plugin)
MONGO_URI=mongodb://mongo:27017/a11y

# --- Redis / BullMQ ---
# Prefer REDIS_URL if your provider exposes one (e.g. Railway Redis plugin):
#   REDIS_URL=redis://default:password@host:6379
# Otherwise set REDIS_HOST / REDIS_PORT / REDIS_PASSWORD individually.
REDIS_HOST=redis
REDIS_PORT=6379

# --- Puppeteer ---
# Inside the api Dockerfile we install Debian chromium:
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# The worker Dockerfile uses the official puppeteer image, which ships its own
# Chrome in the pptruser cache — leave PUPPETEER_EXECUTABLE_PATH unset there.

# --- Security / Limits ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
AUDIT_TIMEOUT_MS=45000
MAX_CONCURRENT_AUDITS=2

# Comma-separated list of allowed origins for CORS. In production set this to
# the deployed frontend URL (e.g. https://accessibility.nicolaspilegidenigris.dev).
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
# Public URL of the api, injected into the Next.js build.
NEXT_PUBLIC_API_URL=http://localhost:4000
